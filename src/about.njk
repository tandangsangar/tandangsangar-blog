---
layout: layouts/base.njk
title: About Us
---

<div class="container mx-auto px-4 py-12 md:py-24">
    <div class="max-w-4xl mx-auto flex flex-col items-center text-center">
        
        <h1 class="text-7xl md:text-[8rem] font-header font-black uppercase text-[#ccff00] leading-none tracking-tighter brutal-shadow border-4 border-black px-6 py-4 bg-black mb-12 transform -rotate-1">
            {{ about.headline | replace('\n', '<br>') | safe }}
        </h1>
        
        <div class="font-mono text-xl md:text-2xl leading-relaxed max-w-2xl mb-16 uppercase font-bold text-black bg-[#f0f0f0] p-8 border-4 border-black brutal-shadow">
            {{ about.description | replace('\n', '<br/><br/>') | safe }}
        </div>

        <div class="w-full border-t-4 border-black pt-12 flex flex-col items-center">
             <h2 class="font-header text-4xl uppercase mb-8">
                CONNECT
             </h2>
             
             <div class="flex flex-wrap justify-center gap-4 w-full">
                 {% for link in about.social_links %}
                 <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" class="group font-header text-2xl uppercase border-4 border-black bg-white px-8 py-4 brutal-shadow hover:bg-black hover:text-[#ccff00] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all text-black w-full md:w-auto">
                     {{ link.platform }} <span class="inline-block transition-transform group-hover:translate-x-2">&rarr;</span>
                 </a>
                 {% endfor %}
             </div>
        </div>

    </div>
</div>

<div class="h-24 md:h-32"></div>