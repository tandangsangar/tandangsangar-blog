<footer class="border-t-0 border-black bg-black text-white">
  <div class="container mx-auto px-4 py-12 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-4 border-b border-[#333] pb-12 mb-8">
        <h2 class="text-7xl md:text-9xl font-header font-black uppercase text-[#ccff00] leading-none tracking-tighter">
          {{ about.headline | replace('\n', '<br>') | safe }}
        </h2>
      </div>
      
      <div class="col-span-1 md:col-span-2">
        <p class="font-mono text-sm md:text-base max-w-md text-gray-400">
          {{ about.description | replace('\n', '<br/>') | safe }}
        </p>
      </div>
      
      <div>
        <h3 class="font-header text-xl mb-4 text-white">SECTIONS</h3>
        <ul class="space-y-2 font-mono text-sm text-gray-400 uppercase">
          <li><a href="/" class="hover:text-[#ccff00] hover:underline">/// HOME</a></li>
          <li><a href="/category/music/" class="hover:text-[#ccff00] hover:underline">/// MUSIC</a></li>
          <li><a href="/category/film/" class="hover:text-[#ccff00] hover:underline">/// FILM</a></li>
          <li><a href="/category/visual/" class="hover:text-[#ccff00] hover:underline">/// VISUAL</a></li>
          <li><a href="/archive/" class="hover:text-[#ccff00] hover:underline">/// ARCHIVE</a></li>
          <li><a href="/radio/" class="hover:text-red-500 hover:underline">/// RADIO</a></li>
          <li><a href="/about/" class="hover:text-[#ccff00] hover:underline">/// ABOUT</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="font-header text-xl mb-4 text-white">CONNECT</h3>
        <ul class="space-y-2 font-mono text-sm text-gray-400">
          {% for link in about.social_links %}
          <li><a href="{{ link.url }}" class="hover:text-[#ccff00] uppercase hover:underline">/// {{ link.platform }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-[#333] flex flex-col md:flex-row justify-between items-center font-mono text-xs text-gray-600 gap-4 md:gap-0">
      <p>&copy; 2026 TANDANG SANGAR MEDIA</p>
      <p>Codec by art student</p>
    </div>
  </div>
</footer>