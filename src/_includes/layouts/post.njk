---
layout: layouts/base.njk
---

<style>
    /* Paksa Font Header buat Judul Artikel */
    .article-content h1, 
    .article-content h2, 
    .article-content h3, 
    .article-content h4,
    .article-content h5,
    .article-content h6 {
        font-family: 'Oswald', sans-serif !important; /* Pake font header lo */
        text-transform: uppercase;
        font-weight: 700 !important; /* Paksa tebal */
        color: #000;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        line-height: 1.1;
    }

    /* Ukuran Heading */
    .article-content h1 { font-size: 2.5rem; } /* Paling gede */
    .article-content h2 { font-size: 2rem; border-left: 5px solid #ccff00; padding-left: 10px; } /* H2 ada aksen garis kuning */
    .article-content h3 { font-size: 1.75rem; }
    
    /* Benerin List (Bullet Points) yang ilang */
    .article-content ul { list-style-type: square; padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .article-content ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .article-content li { margin-bottom: 0.5rem; }
    .article-content li::marker { color: #000; font-weight: bold; }

    /* Benerin Link dalam artikel */
    .article-content a {
        background-color: #ccff00;
        color: #000;
        text-decoration: none;
        padding: 0 4px;
        border: 1px solid #000;
        font-weight: bold;
    }
    .article-content a:hover {
        background-color: #000;
        color: #ccff00;
    }

    /* Blockquote (Kutipan) */
    .article-content blockquote {
        border-left: 8px solid #000;
        background: #f0f0f0;
        padding: 1.5rem;
        margin: 2rem 0;
        font-family: 'Oswald', sans-serif;
        font-size: 1.5rem;
        text-transform: uppercase;
    }

    /* Hide Scrollbar helper */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<article class="min-h-screen border-b-2 border-black bg-white font-mono">
    
    <div class="flex flex-col md:flex-row">
        
        <aside class="w-full md:w-4/12 border-b-2 md:border-b-0 md:border-r-2 border-black bg-[#f0f0f0] md:h-screen md:sticky md:top-0 flex flex-col z-20">
            
            <div class="p-6 md:p-8">
                <a href="/" class="inline-block text-xs font-bold underline underline-offset-4 decoration-2 decoration-black hover:bg-black hover:text-[#ccff00] transition-colors mb-8">
                    &larr; BACK TO ARCHIVE
                </a>
                
                <div>
                    <span class="bg-black text-[#ccff00] px-2 py-1 text-xs font-bold uppercase border border-black inline-block mb-2 shadow-[2px_2px_0px_0px_rgba(0,0,0,0.2)]">
                        {{ category }}
                    </span>
                    <h1 class="font-header text-5xl md:text-6xl lg:text-7xl uppercase leading-[0.85] tracking-tight break-words">
                        {{ title }}
                    </h1>
                </div>
            </div>

            <div class="px-6 md:px-8 py-4 flex-grow flex flex-col justify-end pb-12">
                <div class="border-l-4 border-black pl-4 space-y-6">
                    
                    <div>
                        <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">ARCHIVED BY</p>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-black rounded-full border-2 border-white overflow-hidden shadow-sm flex-shrink-0">
                                {% if author_avatar %}
                                    <img src="{{ author_avatar }}" alt="{{ author }}" class="w-full h-full object-cover">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center text-[#ccff00] font-header text-lg pt-1">
                                        {{ author | truncate(1, true, "") }}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="font-header text-xl uppercase">{{ author }}</span>
                        </div>
                    </div>

                    <div class="flex flex-col gap-4">
                        <div>
                            <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">DATE LOG</p>
                            <p class="font-bold font-mono text-sm bg-white border border-black inline-block px-2 py-1">
                                {{ date | date("DD.MM.YYYY") }}
                            </p>
                        </div>

                        {% set page_tags = p.data.custom_tags if p else custom_tags %}
                        {% if page_tags and (page_tags | length) > 0 %}
                        <div>
                            <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-1">TAGS</p>
                            <div class="flex flex-wrap gap-1">
                                {% for tag in page_tags %}
                                <a href="/tag/{{ tag | slug }}/" class="font-mono text-[10px] font-bold uppercase px-2 py-1 bg-[#ccff00] text-black border border-black hover:bg-black hover:text-[#ccff00] transition-colors shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px]">
                                    #{{ tag }}
                                </a>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </aside>

        <div class="w-full md:w-8/12 bg-white">
    
            <div class="w-full aspect-video border-b-2 border-black overflow-hidden relative">
                <img src="{{ image }}" alt="{{ title }}" class="w-full h-full object-cover">
            </div>

            <div class="p-6 md:p-16 lg:p-20 min-h-[50vh]">
                
                <p class="text-xl md:text-2xl font-serif italic leading-relaxed mb-12 border-l-4 border-[#ccff00] pl-6 py-2 text-gray-800">
                    {{ excerpt }}
                </p>

                <div class="article-content font-serif text-lg leading-8 text-gray-800">
                    
                   {{ content | safe }}
                
                </div>
            </div>

            {% set page_tags = p.data.custom_tags if p else custom_tags %}
            {% if page_tags and (page_tags | length) > 0 %}
            <div class="border-t-2 border-black p-8 md:p-12 bg-white flex flex-wrap gap-2 items-center">
                <span class="font-bold font-mono text-sm mr-2 uppercase">Tags:</span>
                {% for tag in page_tags %}
                <a href="/tag/{{ tag | slug }}/" class="font-mono text-xs font-bold uppercase px-3 py-1 bg-black text-[#ccff00] hover:bg-[#ccff00] hover:text-black border-2 border-black brutal-shadow-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
                    #{{ tag }}
                </a>
                {% endfor %}
            </div>
            {% endif %}

            <div class="border-t-2 border-black p-8 md:p-12 bg-[#ccff00] flex flex-col md:flex-row items-center justify-between gap-6">
                <h3 class="font-header text-3xl md:text-4xl uppercase mb-0 text-center md:text-left">BAGIKAN ARTIKEL</h3>
                <div class="flex flex-wrap gap-4 justify-center md:justify-end">
                    <button onclick="navigator.clipboard.writeText(window.location.href); alert('LINK COPIED TO CLIPBOARD!');" 
                            class="w-14 h-14 bg-white border-2 border-black hover:bg-black hover:text-white hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all flex items-center justify-center group" title="Copy Link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    </button>
                    <a href="whatsapp://send?text={{ title }} - {{ metadata.url }}{{ page.url }}" 
                       class="w-14 h-14 bg-black text-white border-2 border-black hover:bg-white hover:text-black hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none shadow-[4px_4px_0px_0px_#ffffff] transition-all flex items-center justify-center" title="WhatsApp">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    </a>
                    <a href="https://twitter.com/intent/tweet?text={{ title }}&url={{ metadata.url }}{{ page.url }}" target="_blank"
                       class="w-14 h-14 bg-white border-2 border-black hover:bg-black hover:text-white hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all flex items-center justify-center font-bold text-xl" title="Twitter/X">
                        X
                    </a>
                </div>
            </div>

        </div>
    </div>
</article>

<section class="border-b-2 border-black bg-[#f0f0f0] py-12 overflow-hidden">
    <div class="container mx-auto px-4 mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-2">
        <h2 class="font-header text-4xl md:text-6xl uppercase leading-tight md:leading-none">
            ARTIKEL <br class="md:hidden"/>
            <span class="text-[#ccff00] bg-black px-2 inline-block transform -rotate-1 mt-1 md:mt-0">TERKAIT</span>
        </h2>
        <span class="font-mono text-xs hidden md:block animate-pulse">/// SCROLL HORIZONTALLY >>></span>
    </div>
    
    <div class="flex overflow-x-auto overflow-y-hidden gap-6 px-4 pb-8 snap-x snap-mandatory scrollbar-hide">
        
        {% set relatedPosts = collections.posts | filterByCategory(category) %}
        {% set count = 0 %}
        
        {% for post in relatedPosts | reverse %}
            {% if post.url != page.url %} 
                <a href="{{ post.url }}" class="flex-shrink-0 w-[85vw] md:w-[400px] snap-center group block bg-white border-2 border-black brutal-shadow hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all">
                    
                    <div class="aspect-[16/9] border-b-2 border-black overflow-hidden relative">
                        <img src="{{ post.data.image }}" class="w-full h-full object-cover">
                        
                        <div class="absolute top-2 left-2 bg-[#ccff00] px-2 py-1 font-mono text-xs border border-black font-bold">
                            {{ post.date | date("DD MMM") }}
                        </div>
                    </div>
                    
                    <div class="p-6 h-full flex flex-col justify-between">
                        <div>
                            <span class="text-xs font-mono border border-black px-1 mb-2 inline-block text-gray-500 group-hover:bg-black group-hover:text-white transition-colors">
                                {{ post.data.category }}
                            </span>
                            <h3 class="font-header text-2xl uppercase leading-[0.9] group-hover:underline decoration-4 underline-offset-4 decoration-[#ccff00]">
                                {{ post.data.title }}
                            </h3>
                        </div>
                    </div>
                </a>

                {% set count = count + 1 %}
            {% endif %}
        {% endfor %}

        {% if count == 0 %}
             <div class="w-full text-center py-12 border-2 border-dashed border-gray-400 opacity-50 font-mono">
                /// END OF DATA STREAM ///
             </div>
        {% endif %}

        <div class="w-4 flex-shrink-0"></div>

    </div>
</section>

{% if global.newsletter_active %}
<div class="border-t-2 border-black bg-[#ccff00] overflow-hidden">
  <section class="w-full py-24 md:py-32 px-4 md:px-12 flex flex-col items-center justify-center relative overflow-hidden text-center">
    
    <div class="absolute inset-0 z-0 flex items-center justify-center opacity-10 md:opacity-20 pointer-events-none w-full overflow-hidden">
         <h1 class="text-[20vw] font-header font-black text-black leading-none">{{ global.newsletter_home_bg or "SUBSCRIBE" }}</h1>
    </div>
    
    <div class="flex flex-col lg:flex-row items-end lg:items-center justify-between gap-12 max-w-7xl mx-auto w-full relative z-10">
      <div class="lg:w-1/2 text-left w-full">
        <h2 class="text-6xl md:text-8xl font-header uppercase leading-[0.85] mb-6 text-black">
          {{ global.newsletter_home_title | safe if global.newsletter_home_title else "DON'T MISS <br/>THE CHAOS" | safe }}
        </h2>
        <p class="font-mono font-bold text-base md:text-lg max-w-md border-l-4 border-black pl-4 py-1 text-black">
          {{ global.newsletter_home_desc or "Join the collective. We spam maybe once a week. No corporate bs." }}
        </p>
      </div>
      <form action="{{ global.newsletter_home_url or '#' }}" method="POST" class="lg:w-1/2 w-full flex flex-col md:flex-row gap-0 items-stretch brutal-shadow">
        <input type="email" placeholder="{{ global.newsletter_home_placeholder or 'YOUR@EMAIL.COM' }}" required class="flex-grow border-2 border-black p-6 font-mono text-lg focus:outline-none focus:bg-black focus:text-[#ccff00] transition-colors placeholder:text-gray-500 text-black">
        <button type="submit" class="bg-black text-white px-8 py-4 font-bold font-header text-xl uppercase border-2 border-black hover:bg-white hover:text-black transition-all">
          {{ global.newsletter_home_btn or "SUBSCRIBE" }}
        </button>
      </form>
    </div>
  </section>
</div>
{% endif %}

<div class="h-24 w-full flex justify-center bg-white">
</div>